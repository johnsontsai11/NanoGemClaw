# NanoGemClaw Anti-Gravity Ignore File
# This file specifies patterns for files and directories that should be ignored
# by tools like .gitignore, .dockerignore, or similar mechanisms, particularly
# when dealing with build processes, deployments, or source control.
#
# Lines starting with '#' are comments.
# Blank lines are ignored.
# Patterns follow standard .gitignore syntax.

# -----------------------------------------------------------------------------
# Standard Ignore Patterns (often generated by IDEs or build tools)
# -----------------------------------------------------------------------------

# macOS specific files
.DS_Store
.AppleDouble
.LSOverride

# Node.js / npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
.pnp.cjs
.bin/ # not always, but often build-related
dist/ # generally built output
build/ # generally built output
out/ # generally built output
*.tsbuildinfo # TypeScript build info


# IDE and Editor specific files
.vscode/ # VS Code settings
*.sublime-project
*.sublime-workspace
*.bak # Backup files

# Log files
*.log
log/
tmp/
temp/

# Database files (local development and temporary)
*.db
*.sqlite
*.sqlite3
data.sqlite
data.db

# Environment variables (sensitive info or local overrides)
.env
.env.local
.env.*.local
.envrc # direnv

# Backup and temporary files from various editors
*~
#*#
.#*
*.swp
Thumbs.db

# -----------------------------------------------------------------------------
# NanoGemClaw Specific Ignored Patterns
# These are patterns relevant to this specific project that should usually
# not be committed or deployed.
# -----------------------------------------------------------------------------

# Local data & state
store/
data/
logs/
groups/
.omc/

# Secrets
*.keys.json

# Tooling and AI Caches
.claude/
.gemini/
.playwright-mcp/
agents-sdk-docs
docs/learnfromproject.md

# E2E Test Outputs
playwright-report/
test-results/

# Test reports or coverage data
coverage/
.nyc_output/
junit.xml

# VS Code specific launch configurations that might contain local paths
.vscode/launch.json
